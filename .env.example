# The Break Point — Netlify Environment Variables
# Add these in: Netlify Dashboard → Site → Site configuration → Environment variables
# Never commit real values to git.

# Kit (ConvertKit) v4 API key
# Found at: kit.com → Settings → Developer → API Keys → Create API Key
KIT_API_KEY=your_kit_api_key_here

# Kit Tag IDs — create these tags in Kit first, then find their IDs:
# Kit Dashboard → Subscribers → Tags → click a tag → ID is in the URL bar
# e.g. https://app.kit.com/tags/12345678 → ID is 12345678

# Tag: "break-point-completed" — applied to all completers, triggers the nurture automation
KIT_TAG_ID=your_break_point_completed_tag_id

# Achievement pattern tags — applied based on primary pattern result
KIT_TAG_RUNNER=your_bp_runner_tag_id
KIT_TAG_FIXER=your_bp_fixer_tag_id
KIT_TAG_FADER=your_bp_fader_tag_id
KIT_TAG_FIGHTER=your_bp_fighter_tag_id
